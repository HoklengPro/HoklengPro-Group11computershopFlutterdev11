# Copy to .env:  cp .env.example .env
# Used by Podman Compose / Docker Compose

# Nexus Drogon API
NEXUS_API_PORT=8848

# PostgreSQL (optional — profile: with-db)
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus
POSTGRES_DB=nexus
POSTGRES_PORT=5432

# Redis (optional — profile: with-cache) — future cart/session cache
REDIS_PORT=6379
